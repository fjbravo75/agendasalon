DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-only-outside-git
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
# Si Nginx es el único punto de entrada, declarar su IP interna para interpretar
# de forma segura la cadena X-Forwarded-For:
# DJANGO_TRUSTED_PROXY_IPS=127.0.0.1
# Producción exige PostgreSQL y una URL real fuera del repositorio:
# DJANGO_DATABASE_URL=postgresql://usuario:contraseña@servidor:5432/agendasalon?sslmode=require
# Clave independiente del almacenamiento de copias; genera al menos 32 bytes aleatorios:
# AGENDA_BACKUP_HMAC_KEY=replace-with-an-independent-random-secret
# AGENDA_BACKUP_SCHEDULE_CONFIGURED=0
# Identidad del titular de AgendaSalon. Todos estos valores son obligatorios en producción:
# AGENDA_PLATFORM_LEGAL_NAME=Nombre o razón social del titular
# AGENDA_PLATFORM_TAX_ID=NIF-CIF
# AGENDA_PLATFORM_LEGAL_ADDRESS=Domicilio completo
# AGENDA_PLATFORM_PRIVACY_EMAIL=privacidad@example.com
# AGENDA_PLATFORM_WEBSITE=https://agendasalon.example.com
# AGENDA_PLATFORM_LEGAL_DEMO=0
# Una demo académica pública mantiene producción segura, pero no publica ni inventa
# NIF o domicilio. Exige nombre visible, correo y web; TAX_ID y LEGAL_ADDRESS deben
# quedar ausentes o vacíos:
# AGENDA_PLATFORM_LEGAL_NAME=AgendaSalon · demostración académica
# AGENDA_PLATFORM_PRIVACY_EMAIL=contacto@example.com
# AGENDA_PLATFORM_WEBSITE=https://agendasalon.example.com
# AGENDA_PLATFORM_LEGAL_DEMO=1

# Correo transaccional. Debe permanecer desactivado hasta configurar y probar
# un proveedor SMTP real fuera del repositorio. En droplets de DigitalOcean,
# Brevo puede utilizar STARTTLS por el puerto 2525:
# AGENDA_TRANSACTIONAL_EMAIL_ENABLED=0
# Guarda exclusiva de la demo académica: el proceso de regeneración la activa
# temporalmente para impedir cualquier conexión SMTP. Gunicorn debe usar 0.
# AGENDA_DEMO_SUPPRESS_OUTBOUND_EMAIL=0
# Identidad cerrada que el orquestador nocturno inyecta solo al proceso de
# regeneración. Debe coincidir con la conexión PostgreSQL real del despliegue.
# AGENDA_DEMO_EXPECTED_DATABASE_NAME=agendasalon
# AGENDA_DEMO_EXPECTED_DATABASE_USER=agendasalon
# AGENDA_DEMO_EXPECTED_DATABASE_HOST=127.0.0.1
# AGENDA_DEMO_EXPECTED_DATABASE_PORT=5432
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=2525
# EMAIL_HOST_USER=cuenta-smtp@example.com
# EMAIL_HOST_PASSWORD=replace-with-a-secret-outside-git
# DEFAULT_FROM_EMAIL=AgendaSalon <no-responder@example.com>
# EMAIL_USE_TLS=1
# EMAIL_USE_SSL=0
# Tiempo máximo de cada operación del backend SMTP, en segundos:
# EMAIL_TIMEOUT=20
# La reserva del worker debe superar EMAIL_TIMEOUT y se renueva mientras SMTP continúa:
# AGENDA_OUTBOUND_EMAIL_LEASE_SECONDS=120
